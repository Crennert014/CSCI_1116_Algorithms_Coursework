import java.util.Scanner;

public class Exercise22_3 {

    public static void main(String[] args) {
        Scanner input = new Scanner(System.in);

        System.out.print("Enter the first string (text):    ");
        String text = input.nextLine();

        System.out.print("Enter the second string (pattern): ");
        String pattern = input.nextLine();

        int index = kmpSearch(text, pattern);

        if (index >= 0) {
            System.out.println("\"" + pattern + "\" is a substring of \"" + text
                    + "\" starting at index " + index);
        } else {
            System.out.println("\"" + pattern + "\" is not a substring of \"" + text + "\"");
        }
    }

    
    public static int kmpSearch(String text, String pattern) {
        int n = text.length();
        int m = pattern.length();
        if (m == 0) return 0;
        if (m > n) return -1;

        int[] fail = buildFailureTable(pattern);

        int i = 0; // index into text
        int j = 0; // index into pattern

        while (i < n) {
            if (text.charAt(i) == pattern.charAt(j)) {
                i++;
                j++;
                if (j == m) return i - m; // full match found
            } else if (j == 0) {
                i++; // mismatch at start of pattern; advance text
            } else {
                // With distinct neighboring chars, fail[j-1] is always 0 here,
                // so we simply reset j to 0 without moving i.
                j = fail[j - 1];
            }
        }
        return -1; // no match
    }

    /** Builds the KMP partial-match (failure) table in O(m). */
    private static int[] buildFailureTable(String pattern) {
        int m = pattern.length();
        int[] fail = new int[m];
        fail[0] = 0;
        int k = 0;

        for (int i = 1; i < m; i++) {
            while (k > 0 && pattern.charAt(i) != pattern.charAt(k)) {
                k = fail[k - 1];
            }
            if (pattern.charAt(i) == pattern.charAt(k)) {
                k++;
            }
            fail[i] = k;
        }
        return fail;
    }
}

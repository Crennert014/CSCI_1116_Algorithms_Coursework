    public static void playGame(String[][] stateCapitals, Scanner scanner) {
        int correctAnswers = 0;
        List<String[]> questions = new ArrayList<>();
        Collections.addAll(questions, stateCapitals);
        Collections.shuffle(questions); // Randomize questions

      
        for (int i = 0; i < questions.size(); i++) {
            // Prompt the user with a random State Capitol question
            String[] currentQuestion = questions.get(i);
            System.out.print("What is the capital of " + currentQuestion[0] + "? ");
            String capital = scanner.nextLine().trim().toLowerCase();
                if (capital.equals("exit") || capital.equals("quit") || capital.equals("stop")) {
                    System.out.println("Exiting the game. Your final score is " + correctAnswers + " out of " + stateCapitals.length);
                    break;
                }
                    if (capital.toLowerCase().equals(currentQuestion[1].toLowerCase())) {
                    System.out.println("Your answer is correct");
                    correctAnswers++;
                    }
                        else{
                        System.out.println("The correct answer should be " + currentQuestion[1]);
                        }
                        System.out.println("The correct count is " + correctAnswers);
                    }
                }
    }

            

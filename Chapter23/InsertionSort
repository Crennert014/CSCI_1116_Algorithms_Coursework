
    
    // Insertion Sort implementation 
    /* 
     Compare the current element with the one before it
     Shift larger elements right
     Insert the element into the correct position*/


public class InsertionSort {

public static void insertionSort(int[] list) {
    for (int i = 1; i < list.length; i++) {
        int current = list[i];      // The element we want to insert
        int j = i - 1;

        // Shift elements to the right until we find the correct spot
        while (j >= 0 && list[j] > current) {
            list[j + 1] = list[j];
            j--;
        }

        // Insert the element
        list[j + 1] = current;
    }
}
}

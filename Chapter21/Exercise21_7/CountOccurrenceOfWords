
import java.util.*;

public class CountOccurrenceOfWords {
	public static void main(String[] args) {
		// Set text in a string
		String text = "Good morning. Have a good class. " +
			"Have a good visit. Have fun!";

		// Create a TreeMap to hold words as key and count as value
		Map<String, Integer> map = new HashMap<>();

		String[] words = text.split("[\\s+\\p{P}]");
		for (int i = 0; i < words.length; i++) {
			String key = words[i].toLowerCase();
			
			if (key.length() > 0) {
				if (!map.containsKey(key)) {
					map.put(key, 1);
					for (String w : words) {
						if (w.length() > 0) {
							System.out.println(w.toLowerCase() + "\t" + map.get(w.toLowerCase()));
						}
					}

					// System.out.println("Words as Entered of occurrence count: ");
					// System.out.println(key + "\t" + map.get(key));
				}
				else {
					int value = map.get(key);
					value++;
					map.put(key, value);
				}
			}
		}

		// Create WordOccurrence instances and store in ArrayList
		List<WordOccurrence> wordOccurrence = new ArrayList<>();
		for (Map.Entry<String, Integer> entry : map.entrySet()) {
			wordOccurrence.add(new WordOccurrence(entry.getKey(), entry.getValue()));
		}

		WordOccurrence.sortWordOccurrences(wordOccurrence);

		// Display sorted results (by count ascending)
		System.out.println("Words in ascending order of occurrence counts:");
		for (WordOccurrence wo : wordOccurrence) {
			System.out.println(wo);
		
		}
	}
}


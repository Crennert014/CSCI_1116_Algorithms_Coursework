import java.net.URL;
import java.util.HashMap;
import java.util.Map;
import java.util.Scanner;
import javafx.application.Application;
import javafx.geometry.Pos;
import javafx.scene.Scene;
import javafx.scene.control.Button;
import javafx.scene.control.ComboBox;
import javafx.scene.control.Label;
import javafx.scene.control.TextField;
import javafx.scene.layout.BorderPane;
import javafx.scene.layout.GridPane;
import javafx.stage.Stage;

public class BoyGirlNameRanking extends Application {
  private Map<String, Integer>[] boyNameRanks = new HashMap[10];
  private Map<String, Integer>[] girlNameRanks = new HashMap[10];

  private Button btFindRanking = new Button("Find Ranking");
  private ComboBox<Integer> cboYear = new ComboBox<>();
  private ComboBox<String> cboGender = new ComboBox<>();
  private TextField tfName = new TextField();
  private Label lblResult = new Label();

  public BoyGirlNameRanking() {
    for (int i = 0; i < 10; i++) {
      boyNameRanks[i] = new HashMap<>();
      girlNameRanks[i] = new HashMap<>();
    }
  }
  
  @Override // Override the start method in the Application class
  public void start(Stage primaryStage) {
    GridPane gridPane = new GridPane();
    gridPane.add(new Label("Select a year:"), 0, 0);
    gridPane.add(new Label("Boy or girl?"), 0, 1);
    gridPane.add(new Label("Enter a name:"), 0, 2);
    gridPane.add(cboYear, 1, 0);
    gridPane.add(cboGender, 1, 1);
    gridPane.add(tfName, 1, 2);
    gridPane.add(btFindRanking, 1, 3);
    gridPane.setAlignment(Pos.CENTER);
    gridPane.setHgap(5);
    gridPane.setVgap(5);
  
    BorderPane borderPane = new BorderPane();
    borderPane.setCenter(gridPane);
    borderPane.setBottom(lblResult);
    BorderPane.setAlignment(lblResult, Pos.CENTER);

    // Create a scene and place it in the stage
    Scene scene = new Scene(borderPane, 370, 160);
    primaryStage.setTitle("Exercise21_11"); // Set the stage title
    primaryStage.setScene(scene); // Place the scene in the stage
    primaryStage.show(); // Display the stage

    for (int year = 2001; year <= 2010; year++) {
      cboYear.getItems().add(year);
    }
    cboYear.setValue(2001);
    cboGender.getItems().addAll("Male", "Female");
    cboGender.setValue("Male");

    loadRankingData();

    btFindRanking.setOnAction(e -> {
      String name = tfName.getText().trim();
      if (name.isEmpty()) {
        lblResult.setText("Please enter a name.");
        return;
      }

      int year = cboYear.getValue();
      String gender = cboGender.getValue();

      int yearIndex = year - 2001;
      Integer rankFound;

      if ("Male".equals(gender)) {
        rankFound = boyNameRanks[yearIndex].get(name.toLowerCase());
      }
      else {
        rankFound = girlNameRanks[yearIndex].get(name.toLowerCase());
      }

      if (rankFound == null) {
        lblResult.setText(name + " is not ranked in year " + year + ".");
      }
      else {
        String genderLabel = "Male".equals(gender) ? "Boy" : "Girl";
        lblResult.setText(genderLabel + " name is " + name + " and rank is #" + rankFound
            + " in year " + year + ".");
      }
    });
  }

  private void loadRankingData() {
    try {
      for (int year = 2001; year <= 2010; year++) {
        int yearIndex = year - 2001;
        URL url = new URL("https://liveexample.pearsoncmg.com/data/babynamesranking" + year + ".txt");

        try (Scanner input = new Scanner(url.openStream())) {
          while (input.hasNext()) {
            int rank = input.nextInt();
            String boyName = input.next();
            input.nextInt();
            String girlName = input.next();
            input.nextInt();

            boyNameRanks[yearIndex].put(boyName.toLowerCase(), rank);
            girlNameRanks[yearIndex].put(girlName.toLowerCase(), rank);
          }
        }
      }
    }
    catch (Exception ex) {
      lblResult.setText("Unable to preload ranking data.");
    }
  }



  public static void main(String[] args) {
    launch(args);
  }
}

